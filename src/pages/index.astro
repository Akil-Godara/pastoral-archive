---
// Astro frontmatter (optional - you can leave this empty)
---
<!--Force Rebuild for Kuchi Images -->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nomadic Pastoralism Archive</title>
<style>

  /* ============ TOKENS ============ */
  :root{
    --sand: #e4d3b3;
    --sand-pale: #f3ead7;
    --terracotta: #b1532e;
    --terracotta-deep: #8a3d22;
    --rust: #c4622f;
    --charcoal: #221c17;
    --charcoal-soft: #3a322a;
    --ink: #2a221b;
    --thread: #9c7b4f;
    --line: rgba(34,28,23,0.14);
    --cream-line: rgba(243,234,215,0.18);

    --font-display: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif;
    --font-body: Georgia, 'Iowan Old Style', serif;
    --font-mono: 'Courier New', Courier, monospace;
  }

  *{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    margin:0;
    background:var(--sand-pale);
    color:var(--ink);
    font-family:var(--font-body);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  img{ max-width:100%; display:block; }
  a{ color:inherit; text-decoration:none; }
  h1,h2,h3,h4{ font-family:var(--font-display); margin:0; font-weight:700; }
  ::selection{ background:var(--terracotta); color:var(--sand-pale); }

  .eyebrow{
    font-family:var(--font-mono);
    text-transform:uppercase;
    letter-spacing:0.16em;
    font-size:0.72rem;
    color:var(--terracotta-deep);
    display:flex;
    align-items:center;
    gap:0.6em;
  }
  .eyebrow::before{
    content:"";
    width:22px;
    height:1px;
    background:var(--terracotta-deep);
    display:inline-block;
  }

  .wrap{
    max-width:1180px;
    margin:0 auto;
    padding:0 28px;
  }

  /* ============ HEADER ============ */
  header{
    position:sticky;
    top:0;
    z-index:100;
    background:rgba(36,29,23,0.96);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--cream-line);
  }
  .nav-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:16px 28px;
    max-width:1180px;
    margin:0 auto;
  }
  .brand{
    display:flex;
    align-items:center;
    gap:12px;
  }
  .brand-mark{
    width:38px; height:38px;
    border:1.5px solid var(--rust);
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    color:var(--rust);
    font-family:var(--font-mono);
    font-size:0.85rem;
    flex-shrink:0;
  }
  .brand-text h1{
    color:var(--sand-pale);
    font-size:1.18rem;
    letter-spacing:0.01em;
  }
  .brand-text span{
    display:block;
    font-family:var(--font-mono);
    font-size:0.62rem;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--thread);
    margin-top:2px;
  }

  nav.main-nav{
    display:flex;
    align-items:center;
    gap:6px;
  }
  nav.main-nav > ul{
    display:flex;
    list-style:none;
    margin:0; padding:0;
    gap:2px;
  }
  nav.main-nav > ul > li{
    position:relative;
  }
  nav.main-nav > ul > li > a, nav.main-nav > ul > li > button{
    background:none;
    border:none;
    cursor:pointer;
    color:var(--sand-pale);
    font-family:var(--font-mono);
    font-size:0.76rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    padding:10px 14px;
    display:flex;
    align-items:center;
    gap:6px;
    border-radius:3px;
    transition:background 0.2s ease, color 0.2s ease;
  }
  nav.main-nav > ul > li > a:hover,
  nav.main-nav > ul > li > button:hover,
  nav.main-nav > ul > li.open > button{
    background:rgba(196,98,47,0.18);
    color:var(--rust);
  }

  .nav-toggle{
    display:none;
    background:none;
    border:1px solid var(--cream-line);
    border-radius:4px;
    width:42px; height:38px;
    color:var(--sand-pale);
    font-size:1.1rem;
    cursor:pointer;
  }

  /* ============ HERO ============ */
  .hero{
    position:relative;
    background:
      radial-gradient(ellipse at 20% 20%, rgba(196,98,47,0.25), transparent 55%),
      radial-gradient(ellipse at 85% 75%, rgba(177,83,46,0.22), transparent 50%),
      linear-gradient(180deg, var(--charcoal) 0%, #2c241d 100%);
    color:var(--sand-pale);
    overflow:hidden;
    padding:120px 28px 100px;
  }
  .hero::before{
    content:"";
    position:absolute; inset:0;
    background-image:repeating-linear-gradient(
      0deg, rgba(243,234,215,0.025) 0px, rgba(243,234,215,0.025) 1px,
      transparent 1px, transparent 26px
    );
    pointer-events:none;
  }
  .hero-inner{
    max-width:1180px;
    margin:0 auto;
    position:relative;
  }
  .hero .eyebrow{ color:var(--rust); margin-bottom:26px; }
  .hero h2{
    font-size:clamp(2.3rem, 5.4vw, 4.1rem);
    line-height:1.08;
    max-width:14ch;
    color:var(--sand-pale);
    letter-spacing:-0.01em;
  }
  .hero h2 em{
    font-style:italic;
    color:var(--rust);
  }
  .hero-poem{
    margin-top:34px;
    max-width:560px;
    font-size:1.08rem;
    color:rgba(243,234,215,0.82);
    border-left:2px solid var(--terracotta);
    padding-left:22px;
  }
  .hero-poem p{ margin:0 0 14px; }
  .hero-poem p:last-child{ margin-bottom:0; }
  .hero-cta{
    margin-top:42px;
    display:flex;
    gap:16px;
    flex-wrap:wrap;
  }
  .btn{
    font-family:var(--font-mono);
    font-size:0.78rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    padding:14px 26px;
    border-radius:3px;
    border:1px solid transparent;
    cursor:pointer;
    display:inline-block;
  }
  .btn-solid{
    background:var(--terracotta);
    color:var(--sand-pale);
    border-color:var(--terracotta);
  }
  .btn-solid:hover{ background:var(--rust); border-color:var(--rust); }
  .btn-outline{
    border-color:rgba(243,234,215,0.4);
    color:var(--sand-pale);
  }
  .btn-outline:hover{ border-color:var(--rust); color:var(--rust); }

  .hero-stats{
    margin-top:70px;
    display:grid;
    grid-template-columns:repeat(4,1fr);
    border-top:1px solid var(--cream-line);
    padding-top:26px;
    gap:20px;
  }
  .hero-stats div strong{
    display:block;
    font-family:var(--font-display);
    font-size:1.7rem;
    color:var(--sand-pale);
  }
  .hero-stats div span{
    font-family:var(--font-mono);
    font-size:0.66rem;
    text-transform:uppercase;
    letter-spacing:0.1em;
    color:var(--thread);
  }

  /* ============ SECTION HEADERS ============ */
  .section{
    padding:90px 28px;
  }
  .section-head{
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:24px;
    margin-bottom:54px;
    flex-wrap:wrap;
    border-bottom:1px solid var(--line);
    padding-bottom:26px;
  }
  .section-head h3{
    font-size:clamp(1.7rem, 3vw, 2.5rem);
    color:var(--charcoal);
    margin-top:10px;
  }
  .section-head p{
    max-width:380px;
    font-size:0.95rem;
    color:var(--charcoal-soft);
    margin:0;
  }

  /* ============ COMMUNITIES ============ */
  .community{
    display:grid;
    grid-template-columns:0.95fr 1.1fr;
    gap:56px;
    align-items:center;
    margin-bottom:96px;
  }
  .community:last-child{ margin-bottom:0; }
  .community:nth-child(even){
    grid-template-columns:1.1fr 0.95fr;
  }
  .community:nth-child(even) .community-media{ order:2; }
  .community:nth-child(even) .community-text{ order:1; }

  .community-media{
    position:relative;
  }
  .community-media img{
    width:100%;
    height:420px;
    object-fit:cover;
    border-radius:4px;
    filter:saturate(0.92) contrast(1.02);
  }
  .media-tag{
    position:absolute;
    bottom:-1px; left:-1px;
    background:var(--terracotta);
    color:var(--sand-pale);
    font-family:var(--font-mono);
    font-size:0.66rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    padding:9px 14px;
    border-radius:0 4px 0 4px;
  }
  .community-gallery{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
  }
  .community-gallery img{
    width:100%;
    height:220px;
    object-fit:cover;
    display:block;
  }
  
  .community-text .eyebrow{ margin-bottom:16px; }
  .community-text h4{
    font-size:2rem;
    color:var(--charcoal);
    margin-bottom:6px;
  }
  .community-text .region{
    font-family:var(--font-mono);
    font-size:0.74rem;
    letter-spacing:0.08em;
    color:var(--thread);
    text-transform:uppercase;
    margin-bottom:22px;
    display:block;
  }
  .community-text p{
    color:var(--charcoal-soft);
    font-size:0.99rem;
    margin:0 0 16px;
  }
  .community-text p:last-of-type{ margin-bottom:24px; }

  .tag-row{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    margin-bottom:24px;
  }
  .tag-row span{
    font-family:var(--font-mono);
    font-size:0.68rem;
    letter-spacing:0.04em;
    text-transform:uppercase;
    border:1px solid var(--line);
    color:var(--charcoal-soft);
    padding:6px 11px;
    border-radius:20px;
  }
  .read-link{
    font-family:var(--font-mono);
    font-size:0.78rem;
    letter-spacing:0.04em;
    text-transform:uppercase;
    color:var(--terracotta-deep);
    border-bottom:1px solid var(--terracotta-deep);
    padding-bottom:3px;
  }
  .read-link:hover{ color:var(--rust); border-color:var(--rust); }

  /* ============ TABS ============ */
  .tabs{
    display:flex;
    gap:8px;
    margin-bottom:32px;
    flex-wrap:wrap;
  }
  .tab-btn{
    font-family:var(--font-mono);
    font-size:0.74rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    padding:10px 20px;
    border:1px solid var(--line);
    background:transparent;
    color:var(--charcoal-soft);
    border-radius:3px;
    cursor:pointer;
    transition:all 0.2s ease;
  }
  .tab-btn:hover{
    border-color:var(--terracotta);
    color:var(--terracotta);
  }
  .tab-btn.active{
    background:var(--terracotta);
    color:var(--sand-pale);
    border-color:var(--terracotta);
  }
  .tab-content{
    display:none;
  }
  .tab-content.active{
    display:block;
  }

  /* ============ IMAGE GALLERY ============ */
  .gallery-section{
    background:var(--sand);
  }
  .gallery-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(280px, 1fr));
    gap:16px;
  }
  .gallery-item{
    position:relative;
    overflow:hidden;
    border-radius:4px;
    aspect-ratio:4/3;
    cursor:pointer;
    transition:transform 0.3s ease;
  }
  .gallery-item:hover{
    transform:translateY(-4px);
  }
  .gallery-item img{
    width:100%;
    height:100%;
    object-fit:cover;
    transition:transform 0.3s ease;
  }
  .gallery-item:hover img{
    transform:scale(1.05);
  }
  .gallery-caption{
    position:absolute;
    bottom:0;
    left:0;
    right:0;
    background:linear-gradient(transparent, rgba(34,28,23,0.9));
    color:var(--sand-pale);
    padding:40px 14px 12px;
    font-size:0.88rem;
    opacity:0;
    transition:opacity 0.3s ease;
  }
  .gallery-item:hover .gallery-caption{
    opacity:1;
  }
  .gallery-category{
    font-family:var(--font-mono);
    font-size:0.66rem;
    text-transform:uppercase;
    letter-spacing:0.08em;
    color:var(--rust);
    margin-bottom:4px;
  }

  /* ============ PDF ARCHIVE ============ */
  .pdf-section{
    background:var(--sand-pale);
  }
  .pdf-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(320px, 1fr));
    gap:24px;
  }
  .pdf-card{
    background:var(--sand-pale);
    border:1px solid var(--line);
    border-radius:6px;
    padding:28px;
    transition:transform 0.2s ease, box-shadow 0.2s ease;
    display:flex;
    flex-direction:column;
  }
  .pdf-card:hover{
    transform:translateY(-4px);
    box-shadow:0 8px 24px rgba(34,28,23,0.12);
  }
  .pdf-icon{
    width:48px;
    height:48px;
    background:var(--terracotta);
    border-radius:4px;
    display:flex;
    align-items:center;
    justify-content:center;
    color:var(--sand-pale);
    font-size:1.4rem;
    margin-bottom:18px;
  }
  .pdf-card h4{
    font-size:1.05rem;
    color:var(--charcoal);
    margin-bottom:8px;
    line-height:1.3;
  }
  .pdf-meta{
    font-family:var(--font-mono);
    font-size:0.68rem;
    color:var(--thread);
    text-transform:uppercase;
    letter-spacing:0.06em;
    margin-bottom:12px;
  }
  .pdf-card p{
    font-size:0.88rem;
    color:var(--charcoal-soft);
    margin:0 0 18px;
    flex-grow:1;
  }
  .pdf-download{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-family:var(--font-mono);
    font-size:0.74rem;
    text-transform:uppercase;
    letter-spacing:0.04em;
    color:var(--terracotta-deep);
    border:1px solid var(--terracotta-deep);
    padding:10px 18px;
    border-radius:3px;
    justify-self:start;
    transition:background 0.2s ease, color 0.2s ease;
  }
  .pdf-download:hover{
    background:var(--terracotta);
    color:var(--sand-pale);
  }

  /* ============ MAPS SECTION ============ */
  .maps-section{
    background:var(--charcoal);
    color:var(--sand-pale);
  }
  .maps-section .section-head h3{
    color:var(--sand-pale);
  }
  .maps-section .section-head p{
    color:rgba(243,234,215,0.72);
  }
  .maps-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(340px, 1fr));
    gap:28px;
  }
  .map-card{
    background:var(--charcoal-soft);
    border:1px solid var(--cream-line);
    border-radius:6px;
    overflow:hidden;
    transition:transform 0.2s ease;
  }
  .map-card:hover{
    transform:translateY(-4px);
  }
  .map-preview{
    width:100%;
    height:220px;
    position:relative;
    overflow:hidden;
  }
  .map-preview img{
    width:100%;
    height:100%;
    object-fit:cover;
    transition:transform 0.3s ease;
  }
  .map-card:hover .map-preview img{
    transform:scale(1.05);
  }
  .map-overlay{
    position:absolute;
    inset:0;
    background:rgba(34,28,23,0.5);
    display:flex;
    align-items:center;
    justify-content:center;
    opacity:0;
    transition:opacity 0.2s ease;
  }
  .map-card:hover .map-overlay{
    opacity:1;
  }
  .map-view{
    font-family:var(--font-mono);
    font-size:0.74rem;
    text-transform:uppercase;
    letter-spacing:0.08em;
    background:var(--terracotta);
    color:var(--sand-pale);
    padding:12px 24px;
    border-radius:3px;
  }
  .map-content{
    padding:24px;
  }
  .map-content h4{
    font-size:1.15rem;
    color:var(--sand-pale);
    margin-bottom:8px;
  }
  .map-content .map-type{
    font-family:var(--font-mono);
    font-size:0.66rem;
    color:var(--rust);
    text-transform:uppercase;
    letter-spacing:0.08em;
    margin-bottom:12px;
    display:block;
  }
  .map-content p{
    font-size:0.88rem;
    color:rgba(243,234,215,0.72);
    margin:0 0 16px;
  }

  /* ============ FEEDBACK ============ */
  .feedback{
    background:var(--charcoal);
    color:var(--sand-pale);
    position:relative;
    overflow:hidden;
  }
  .feedback::before{
    content:"";
    position:absolute; inset:0;
    background-image:repeating-linear-gradient(
      90deg, rgba(243,234,215,0.025) 0px, rgba(243,234,215,0.025) 1px,
      transparent 1px, transparent 26px
    );
    pointer-events:none;
  }
  .feedback-grid{
    display:grid;
    grid-template-columns:0.85fr 1.15fr;
    gap:64px;
    position:relative;
  }
  .feedback-intro .eyebrow{ color:var(--rust); margin-bottom:20px; }
  .feedback-intro h3{
    font-size:clamp(1.7rem,3vw,2.4rem);
    margin-bottom:18px;
  }
  .feedback-intro p{
    color:rgba(243,234,215,0.72);
    font-size:0.98rem;
    max-width:38ch;
  }

  form.feedback-form{
    display:grid;
    gap:20px;
  }
  .form-row{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
  }
  .field{
    display:flex;
    flex-direction:column;
    gap:8px;
  }
  .field label{
    font-family:var(--font-mono);
    font-size:0.68rem;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--thread);
  }
  .field input,
  .field textarea{
    background:rgba(243,234,215,0.05);
    border:1px solid var(--cream-line);
    border-radius:3px;
    padding:13px 14px;
    color:var(--sand-pale);
    font-family:var(--font-body);
    font-size:0.96rem;
    resize:vertical;
  }
  .field textarea{ min-height:130px; }
  .field input::placeholder,
  .field textarea::placeholder{ color:rgba(243,234,215,0.32); }
  .field input:focus,
  .field textarea:focus{
    outline:none;
    border-color:var(--terracotta);
    background:rgba(243,234,215,0.08);
  }
  .feedback-form button{
    justify-self:start;
    margin-top:6px;
  }

  /* ============ FOOTER ============ */
  footer{
    background:#19140f;
    color:var(--sand-pale);
    padding:64px 28px 28px;
  }
  .footer-grid{
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:48px;
    padding-bottom:40px;
    border-bottom:1px solid rgba(243,234,215,0.1);
  }
  .footer-brand h4{
    font-size:1.2rem;
    color:var(--sand-pale);
    margin-bottom:10px;
  }
  .footer-brand p{
    font-size:0.88rem;
    color:rgba(243,234,215,0.5);
    max-width:32ch;
    margin:0;
  }
  .footer-social{
    display:flex;
    flex-direction:column;
    gap:14px;
  }
  .footer-social span.label{
    font-family:var(--font-mono);
    font-size:0.66rem;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--thread);
    margin-bottom:4px;
  }
  .social-links{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
  }
  .social-links a{
    font-family:var(--font-mono);
    font-size:0.76rem;
    letter-spacing:0.03em;
    border:1px solid rgba(243,234,215,0.18);
    padding:9px 16px;
    border-radius:20px;
    color:var(--sand-pale);
    transition:border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .social-links a:hover{
    border-color:var(--rust);
    color:var(--rust);
    background:rgba(196,98,47,0.1);
  }
  .footer-bottom{
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:12px;
    padding-top:26px;
    font-family:var(--font-mono);
    font-size:0.74rem;
    color:rgba(243,234,215,0.45);
  }
  .footer-bottom .credit{ color:rgba(243,234,215,0.7); }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 900px){
    .community, .community:nth-child(even){
      grid-template-columns:1fr;
      gap:28px;
    }
    .community-media, .community:nth-child(even) .community-media{ order:1; }
    .community-text, .community:nth-child(even) .community-text{ order:2; }
    .community-media img{ height:300px; }
    .feedback-grid{ grid-template-columns:1fr; gap:40px; }
    .hero-stats{ grid-template-columns:repeat(2,1fr); row-gap:30px; }
  }

  @media (max-width: 760px){
    nav.main-nav{
      position:absolute;
      top:100%; left:0; right:0;
      background:var(--charcoal-soft);
      border-bottom:1px solid var(--cream-line);
      flex-direction:column;
      align-items:stretch;
      padding:10px;
      display:none;
    }
    nav.main-nav.show{ display:flex; }
