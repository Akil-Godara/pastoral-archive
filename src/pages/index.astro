<script>
  document.addEventListener('DOMContentLoaded', function() {
    
    // 1. TAB SWITCHING LOGIC (Bulletproof version)
    const allTabBtns = document.querySelectorAll('.tab-btn');
    
    allTabBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const targetId = this.getAttribute('data-tab');
        const targetContent = document.getElementById(targetId);
        
        if (!targetContent) return;

        // Find the parent section to only affect tabs in this specific area
        const parentSection = this.closest('.wrap') || this.closest('section');
        
        // Hide all contents and deactivate all buttons in this section
        parentSection.querySelectorAll('.tab-content').forEach(content => {
          content.classList.remove('active');
        });
        parentSection.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('active');
        });

        // Show the clicked content and activate the button
        targetContent.classList.add('active');
        this.classList.add('active');
      });
    });

    // 2. MOBILE NAV TOGGLE
    const navToggle = document.getElementById('navToggle');
    const mainNav = document.getElementById('mainNav');
    if (navToggle && mainNav) {
      navToggle.addEventListener('click', () => mainNav.classList.toggle('show'));
      mainNav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => mainNav.classList.remove('show'));
      });
    }

    // 3. FORCE SINGLE IMAGE IN COMMUNITY GALLERIES
    document.querySelectorAll('.community-gallery').forEach(gallery => {
      const images = gallery.querySelectorAll('img');
      images.forEach((img, index) => {
        img.style.display = index === 0 ? 'block' : 'none';
      });
      gallery.style.gridTemplateColumns = '1fr';
    });

  });
</script>  

